{
  "name": "shellreq-api-client",
  "displayName": "ShellReq API Client",
  "description": "Lightweight API testing extension powered by ShellReq with JSON response formatting and easy execution.",
  "version": "0.1.0",
  "publisher": "maheshshinde9100",
  "author": "Mahesh Shinde (maheshshinde9100)",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/maheshshinde9100/ShellReq"
  },
  "license": "MIT",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shellreq-explorer",
          "title": "ShellReq",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "shellreq-explorer": [
        {
          "type": "webview",
          "id": "shellreq.clientView",
          "name": "API Client",
          "icon": "icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "shellreq-api-client.runRequest",
        "title": "ShellReq: Run Request"
      },
      {
        "command": "shellreq.focus",
        "title": "ShellReq: Focus API Client"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "shellreq": "^0.2.0"
  }
}