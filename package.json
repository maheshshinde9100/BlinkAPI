{
  "name": "shellreq",
  "version": "0.2.0",
  "description": "A lightweight terminal-native API testing tool.",
  "main": "dist/index.js",
  "bin": {
    "shellreq": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maheshshinde9100/ShellReq.git"
  },
  "keywords": [
    "cli",
    "api",
    "testing",
    "rest",
    "http",
    "terminal"
  ],
  "author": "Mahesh Shinde",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/maheshshinde9100/ShellReq/issues"
  },
  "homepage": "https://github.com/maheshshinde9100/ShellReq#readme",
  "dependencies": {
    "axios": "^1.16.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "ink": "^7.0.2",
    "ink-big-text": "^2.0.0",
    "ink-box": "^1.0.0",
    "ink-gradient": "^4.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
